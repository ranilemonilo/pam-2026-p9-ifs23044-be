## Global Variables
@baseurl=http://127.0.0.1:5000

## ─── Login ────────────────────────────────────────────────────────────────────
# @name PostLogin
POST {{baseurl}}/recipes/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123"
}

###
## Response PostLogin
# {
#   "token": "admin:admin123",
#   "message": "Login berhasil"
# }


## ─── Generate Recipe ──────────────────────────────────────────────────────────
# @name PostGenerateRecipe
POST {{baseurl}}/recipes/generate
Content-Type: application/json
X-Admin-Token: admin:admin123

{
  "category": "masakan Padang",
  "total": 3
}

###
## Response PostGenerateRecipe
# {
#   "data": [
#     {
#       "id": 1,
#       "title": "Rendang Daging Sapi",
